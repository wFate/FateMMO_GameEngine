# =============================================================================
# Proprietary game logic & content (kept local, not pushed to public repo)
# =============================================================================

# Core game systems — combat formulas, loot tables, economy, balance numbers
game/shared/

# Game system implementations — AI behavior, spawn logic, combat actions
game/systems/

# Entity factory — defines how game entities are composed with specific stats
game/entity_factory.h

# Game app — ties all proprietary systems together
game/game_app.cpp
game/game_app.h

# Game content data — prefabs, scenes, level layouts
assets/prefabs/
assets/scenes/

# Custom art assets
assets/sprites/
assets/tiles/
