# =============================================================================
# Proprietary game logic & content (kept local, not pushed to public repo)
# =============================================================================

# Game — all proprietary (shared, systems, components, sprites, oldscripts, etc.)
game/

# Game content data — prefabs, scenes, level layouts
assets/prefabs/
assets/scenes/

# Custom art assets
assets/sprites/
assets/tiles/

# Audio assets & engine wrapper
engine/audio/audio_manager.h
engine/audio/audio_manager.cpp
assets/audio/sfx/
assets/audio/music/

# All assets (superset — covers sprites, tiles, audio, etc.)
assets/

# Server — all proprietary (auth, DB repos, caches, WAL, handlers)
server/

# Game-specific HUD widgets (engine/ui/widgets/ base types are public, these are game-specific)
