# =============================================================================
# Proprietary game logic & content (kept local, not pushed to public repo)
# =============================================================================

# Game — all proprietary (shared, systems, components, sprites, oldscripts, etc.)
/game/

# Game content data — prefabs, scenes, level layouts
assets/prefabs/
assets/scenes/

# Custom art assets
assets/sprites/
assets/tiles/

# Audio assets & engine wrapper
engine/audio/audio_manager.h
engine/audio/audio_manager.cpp
assets/audio/sfx/
assets/audio/music/

# All assets (superset — covers sprites, tiles, audio, etc.)
# Use wildcard so negation rules can un-ignore specific subdirs
assets/*

# Open-source: shader files (rendering infrastructure, not game content)
!assets/shaders/
# Open-source: UI screen layouts
!assets/ui/

# Server — all proprietary (auth, DB repos, caches, WAL, handlers)
server/

# UI system — all proprietary (core + widgets)
engine/ui/

# Server WAL binary
server_wal.bin

# Tests — proprietary game logic tests
tests/

# Internal docs — all proprietary
Docs/
docs/superpowers/

# Scripts with credentials (backup scripts, deploy, etc.)
scripts/
run_server.ps1

# ImGui layout (per-developer)
imgui.ini

# Claude memory & tooling
.claude/

# iOS platform files (proprietary)
ios/Info.plist.in
ios/Podfile

# Ad service platform integration (proprietary)
engine/platform/ad_service.h
engine/platform/ad_service_android.cpp
engine/platform/ad_service_ios.mm
engine/platform/ad_service_stub.cpp

# Android platform files (proprietary)
android/app/src/main/AndroidManifest.xml
android/app/src/main/java/com/fatemmo/game/AdBridge.java
